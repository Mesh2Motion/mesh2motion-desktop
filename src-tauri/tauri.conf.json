{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mesh2Motion",
  "version": "0.1.4",
  "identifier": "com.mesh2motion.desktop",
  "build": {
    "devUrl": null,
    "frontendDist": "../mesh2motion-app/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Mesh2Motion",
        "width": 1100,
        "height": 700,
        "resizable": true
      }
    ]
  },
    "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["nsis", "appimage", "dmg", "app"]
  }
}
